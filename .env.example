NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=info
EARNABLE_BACKEND_PORT=3300
EARNABLE_DB_PORT=55433
EARNABLE_REDIS_PORT=56379

DATABASE_HOST=localhost
DATABASE_PORT=55433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=earnable

REDIS_HOST=localhost
REDIS_PORT=56379

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=5
THROTTLE_DEFAULT_TTL=60
THROTTLE_DEFAULT_LIMIT=100

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_TIMEOUT_MS=15000
# OPENAI_API_KEY=sk-... # required only when LLM_PROVIDER=openai
INGESTION_ENABLED=false
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_MS=15000
# FIRECRAWL_API_KEY=fc-... # required only when INGESTION_ENABLED=true
INGESTION_MAX_CHARS=12000
