{
  "info": {
    "name": "Earnable Backend API",
    "_postman_id": "1f6d0f0a-a4dd-47d9-a28f-9d160a8fb472",
    "description": "Canonical customer journey: readiness -> onboarding -> crawl/save -> analyze by ingestion id -> optional LLM debug -> session lifecycle.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3300"
    },
    {
      "key": "email",
      "value": "postman.user+{{$timestamp}}@example.com"
    },
    {
      "key": "password",
      "value": "Password123!"
    },
    {
      "key": "sourceUrl",
      "value": "https://example.com"
    },
    {
      "key": "ingestionId",
      "value": ""
    },
    {
      "key": "analysisId",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0. Platform Readiness",
      "item": [
        {
          "name": "Health Check - GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "1. Customer Onboarding (Auth)",
      "item": [
        {
          "name": "Sign Up - POST /auth/signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Sign In - POST /auth/signin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signin"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken || '');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Crawl and Save Content",
      "item": [
        {
          "name": "Crawl URL - POST /ingestion/crawl",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"{{sourceUrl}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ingestion/crawl",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ingestion",
                "crawl"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('ingestionId', json.ingestionId || '');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Analyze Saved Crawl (Enterprise Narrative)",
      "item": [
        {
          "name": "Run Analysis - POST /analysis/run",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ingestionId\": \"{{ingestionId}}\",\n  \"analysisType\": \"enterprise-positioning\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analysis/run",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "analysis",
                "run"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('analysisId', json.analysisId || '');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Optional LLM Debug Endpoints",
      "item": [
        {
          "name": "LLM Smoke - POST /llm/smoke",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/llm/smoke",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "llm",
                "smoke"
              ]
            }
          }
        },
        {
          "name": "LLM Complete (Message Mode) - POST /llm/complete",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Write one concise line on enterprise content monetization.\" }\n  ],\n  \"taskType\": \"general\",\n  \"templateVersion\": \"v1\",\n  \"temperature\": 0.2,\n  \"maxTokens\": 120\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/llm/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "llm",
                "complete"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Session Lifecycle",
      "item": [
        {
          "name": "Refresh Session - POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout - POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Refresh After Logout (Expected 401) - POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        }
      ]
    }
  ]
}
